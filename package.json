{
    "name": "@fiduswriter/document-template-editor",
    "version": "0.1.1",
    "description": "Fidus Writer document template editor",
    "repository": {
        "type": "git",
        "url": "ssh://git@codeberg.org/fiduswriter/fiduswriter-document-template-editor-js.git"
    },
    "license": "AGPL-3.0",
    "author": "Johannes Wilm",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "default": "./dist/*.js"
        }
    },
    "files": [
        "dist/",
        "src/",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "prepare": "npm run build",
        "prepublishOnly": "npm run build",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "@fiduswriter/document": "^0.2.20",
        "@fiduswriter/editor": "^0.1.17",
        "citeproc-plus": "^1.0.2",
        "downloadjs": "^1.4.7",
        "fast-deep-equal": "^3.1.3",
        "fwtoolkit": "^0.1.9",
        "jszip": "^3.10.1",
        "prosemirror-commands": "^1.7.0",
        "prosemirror-example-setup": "^1.2.3",
        "prosemirror-gapcursor": "^1.3.2",
        "prosemirror-history": "^1.3.2",
        "prosemirror-keymap": "^1.2.2",
        "prosemirror-menu": "^1.2.4",
        "prosemirror-model": "^1.25.0",
        "prosemirror-schema-basic": "^1.2.4",
        "prosemirror-state": "^1.4.3",
        "prosemirror-tables": "^1.6.4",
        "prosemirror-view": "^1.38.1",
        "sortablejs": "^1.15.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.6.0",
        "globals": "^15.15.0",
        "prettier": "^3.5.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0"
    }
}
